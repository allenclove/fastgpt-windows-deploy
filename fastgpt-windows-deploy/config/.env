# ==================== FastGPT Windows 本地部署配置 ====================
# 基础配置
LOG_DEPTH=3
DEFAULT_ROOT_PSW=123456
DB_MAX_LINK=5
SYNC_INDEX=1
TOKEN_KEY=fastgpt
FILE_TOKEN_KEY=1234567890abcdef1234567890abcdef
AES256_SECRET_KEY=fastgptsecret
ROOT_KEY=fdafasd
MULTIPLE_DATA_TO_BASE64=true

# 辅助生成模型
HELPER_BOT_MODEL=qwen-max

# ==================== 数据库与缓存 ====================
# MongoDB (本地 Windows)
MONGODB_URI=mongodb://fastgpt:fastgpt123@127.0.0.1:27017/fastgpt?authSource=admin&directConnection=true
MONGODB_LOG_URI=mongodb://fastgpt:fastgpt123@127.0.0.1:27017/fastgpt?authSource=admin&directConnection=true

# Redis (本地 Windows)
REDIS_URL=redis://:fastgpt123@127.0.0.1:6379

# PG 向量库
PG_URL=postgresql://fastgpt:fastgpt123@127.0.0.1:5432/postgres
VECTOR_VQ_LEVEL=32

# ==================== 对象存储 (MinIO) ====================
STORAGE_VENDOR=minio
STORAGE_REGION=us-east-1
STORAGE_ACCESS_KEY_ID=minioadmin
STORAGE_SECRET_ACCESS_KEY=minioadmin
STORAGE_PUBLIC_BUCKET=fastgpt-public
STORAGE_PRIVATE_BUCKET=fastgpt-private
STORAGE_EXTERNAL_ENDPOINT=http://127.0.0.1:9000
STORAGE_S3_ENDPOINT=http://127.0.0.1:9000
STORAGE_S3_FORCE_PATH_STYLE=true
STORAGE_S3_MAX_RETRIES=3

# ==================== 服务地址 ====================
FE_DOMAIN=http://localhost:4000
FILE_DOMAIN=http://localhost:4000

# 插件服务 (本地)
PLUGIN_BASE_URL=http://localhost:4004
PLUGIN_TOKEN=token

# 代码沙箱 (本地)
CODE_SANDBOX_URL=http://localhost:4002
CODE_SANDBOX_TOKEN=codesandbox

# AI Proxy
AIPROXY_API_ENDPOINT=http://localhost:3010
AIPROXY_API_TOKEN=token

# ==================== Agent 沙盒配置 ====================
AGENT_SANDBOX_PROVIDER=opensandbox
AGENT_SANDBOX_OPENSANDBOX_BASEURL=http://localhost:8090
AGENT_SANDBOX_OPENSANDBOX_RUNTIME=docker
AGENT_SANDBOX_ENABLE_VOLUME=false

# ==================== 日志 ====================
LOG_ENABLE_CONSOLE=true
LOG_CONSOLE_LEVEL=debug
LOG_ENABLE_OTEL=false

# ==================== 安全与限制 ====================
USE_IP_LIMIT=false
WORKFLOW_MAX_RUN_TIMES=500
WORKFLOW_MAX_LOOP_TIMES=100
WORKFLOW_PARALLEL_MAX_CONCURRENCY=10
SERVICE_REQUEST_MAX_CONTENT_LENGTH=10
CHECK_INTERNAL_IP=false
UPLOAD_FILE_MAX_SIZE=1000
UPLOAD_FILE_MAX_AMOUNT=1000

# ==================== AI 模型配置 ====================
# OpenAI 兼容 API (讯飞 astron-code-latest)
OPENAI_BASE_URL=https://maas-coding-api.cn-huabei-1.xf-yun.com/v2
CHAT_API_KEY=4d567ab779c243ab8a6cb07323c1fbbc:N2MxZmJhYWRkMGUwMDM4ODI1MDJkZWM4
HELPER_BOT_MODEL=astron-code-latest

# ==================== 功能开关 ====================
SHOW_COUPON=false
SHOW_DISCOUNT_COUPON=false
SHOW_SKILL=false
AGENT_ENGINE=default
MARKETPLACE_URL=https://marketplace.fastgpt.cn
